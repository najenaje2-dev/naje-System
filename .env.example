# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/bennaaji-erp
DB_NAME=bennaaji_erp

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production_now
JWT_EXPIRE=7d

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Notifications
NOTIFICATION_ENABLED=true
NOTIFICATION_SERVICE=local

# API Keys
API_KEY=your_api_key_here

# Timezone
TIMEZONE=Africa/Tripoli

# CORS
CORS_ORIGIN=*
